#!name=91Porn 短视频
#!desc=91Porn PWA: 完整视频(10play→long) + 付费/VIP解锁 + 去广告，默认常开无开关
#!icon=https://raw.githubusercontent.com/Yu9191/91sp/refs/heads/main/modules/91porn.png
#!author=Yu9191
#!category=18+
#!arguments=日志级别:error,播放器:lenna,自定义scheme:none,URL编码:default,播放器跳转:no
#!arguments-desc=去广告/完整视频/VIP解锁默认常开。\n日志级别: error(默认) / off / warn / info / debug / all\n播放器: lenna / SenPlayer / SenPlayer-dl / Infuse / Fileball / VidHub / IINA / Alook / VLC / KMPlayer / NPlayer / Safari\n自定义scheme: 填写后覆盖播放器；留 none 不启用\nURL编码: yes / no / default(默认)\n播放器跳转: yes 打开视频详情弹通知跳转到外部播放器 / no(默认)

[Script]
91porn = type=http-request, pattern=^https?:\/\/[^/]+\/pwa\.php, requires-body=1, max-size=-1, timeout=30, script-path=https://raw.githubusercontent.com/Yu9191/91sp/refs/heads/main/dist/91porn.js, argument=logLevel={{{日志级别}}}&player={{{播放器}}}&scheme={{{自定义scheme}}}&encode={{{URL编码}}}&jump={{{播放器跳转}}}

[MITM]
# 91Porn 业务接口统一打到 <随机子域>.<轮换顶级域>/pwa.php，主机会随机轮换。
# 接口换主机时把新主机/新顶级域加进来即可（MITM 不区分端口）。
hostname = %APPEND% *.yxrznglgy.cc, *.nkbvfuvu.cc
